{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"declaration": true,
		"sourceMap": false,
		"declarationMap": false,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"paths": {
			"unorepo-alpha": ["../"]
		}
	},
	"include": ["*.ts", "./commands"]
}
